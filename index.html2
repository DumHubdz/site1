<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Key System</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI',sans-serif;
}

body{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background: radial-gradient(circle at top,#0f172a,#020617);
  color:white;
}

.container{
  width:340px;
  padding:25px;
  border-radius:25px;
  background:rgba(15,23,42,0.7);
  backdrop-filter:blur(20px);
  box-shadow:0 0 40px rgba(0,255,255,0.08);
  text-align:center;
  animation:fadeIn 0.8s ease;
}

@keyframes fadeIn{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;}
}

h2{
  margin-bottom:15px;
  font-weight:600;
}

/* BOX */
.box{
  display:inline-flex;
  justify-content:center;
  align-items:center;
  width:85px;
  height:85px;
  margin:6px;
  border-radius:15px;
  background:#1e293b;
  cursor:pointer;
  font-size:20px;
  transition:0.3s;
}

.box:hover{
  transform:scale(1.08);
  box-shadow:0 0 12px rgba(34,197,94,0.4);
}

.box.done{
  background:#22c55e;
}

/* BUTTON */
button{
  margin-top:12px;
  padding:12px;
  width:100%;
  border:none;
  border-radius:12px;
  font-size:15px;
  cursor:pointer;
  transition:0.25s;
}

#getKeyBtn{
  background:#22c55e;
  display:none;
}

.copyBtn{
  background:#3b82f6;
  display:none;
}

button:hover{
  transform:scale(1.04);
  filter:brightness(1.1);
}

/* TEXT */
#status{
  margin-top:10px;
  font-size:14px;
  color:#94a3b8;
}

#keyDisplay{
  margin-top:10px;
  font-size:14px;
  color:#22c55e;
  word-break:break-all;
}

#countdown{
  margin-top:8px;
  font-size:13px;
  color:#facc15;
}
</style>
</head>

<body>

<div class="container">
<h2>Key System</h2>

<div>
  <div class="box" onclick="startTimer(1,30)">1</div>
  <div class="box" onclick="startTimer(2,40)">2</div>
  <div class="box" onclick="startTimer(3,50)">3</div>
</div>

<p id="status"></p>

<button id="getKeyBtn" onclick="getKey()">Get Key</button>
<button id="copyBtn" class="copyBtn" onclick="copyKey()">Copy Key</button>

<div id="keyDisplay"></div>
<div id="countdown"></div>
</div>

<script>

let done=[false,false,false];
let currentKey="";

function resetTask(){
  done=[false,false,false];

  let boxes=document.getElementsByClassName("box");
  for(let i=0;i<boxes.length;i++){
    boxes[i].innerText=i+1;
    boxes[i].classList.remove("done");
  }

  getKeyBtn.style.display="none";
  copyBtn.style.display="none";
  status.innerText="";
  keyDisplay.innerText="";
}

function startTimer(i,t){
  let box=document.getElementsByClassName("box")[i-1];
  if(done[i-1]) return;

  let iv=setInterval(()=>{
    t--;
    box.innerText=t+"s";

    if(t<=0){
      clearInterval(iv);
      box.innerText="Done";
      box.classList.add("done");
      done[i-1]=true;

      if(done.every(v=>v)){
        getKeyBtn.style.display="block";
        status.innerText="Completed";
      }
    }
  },1000);
}

function genKey(){
  let num=Math.floor(1000000+Math.random()*9000000);
  return "KidHubJPW"+num;
}

function getKey(){
  let now=Date.now();
  let data=JSON.parse(localStorage.getItem("keyData")||"null");

  if(data && now<data.expire){
    showKey(data.key,data.expire);
    return;
  }

  let key=genKey();
  let expire=now+86400000;

  localStorage.setItem("keyData",JSON.stringify({
    key:key,
    expire:expire
  }));

  showKey(key,expire);
}

function showKey(key,expire){
  currentKey=key;
  keyDisplay.innerText="Key: "+key;
  copyBtn.style.display="block";
  startCountdown(expire);
}

function copyKey(){
  navigator.clipboard.writeText(currentKey);
  copyBtn.innerText="Copied";
  setTimeout(()=>copyBtn.innerText="Copy Key",1000);
}

let cd;
function startCountdown(expire){
  clearInterval(cd);

  cd=setInterval(()=>{
    let diff=expire-Date.now();

    if(diff<=0){
      countdown.innerText="Expired";
      localStorage.removeItem("keyData");
      resetTask();
      clearInterval(cd);
      return;
    }

    let h=Math.floor(diff/3600000);
    let m=Math.floor((diff%3600000)/60000);
    let s=Math.floor((diff%60000)/1000);

    countdown.innerText=`${h}h ${m}m ${s}s`;
  },1000);
}

window.onload=()=>{
  let data=JSON.parse(localStorage.getItem("keyData")||"null");

  if(data && Date.now()<data.expire){
    showKey(data.key,data.expire);
    done=[true,true,true];
    getKeyBtn.style.display="block";
    status.innerText="Have key";
  }else{
    resetTask();
  }
}

</script>

</body>
  </html>
